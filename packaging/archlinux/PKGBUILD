# Maintainer: BYUNG-IK YEUN <yeun0908@gmail.com>
pkgname=logicutils
pkgver=0.1.0
pkgrel=1
pkgdesc="Composable Unix-style utilities for logic-enhanced builds (multi-wildcards, content-based freshness, logic engine, parallel/cluster execution)"
arch=('x86_64' 'aarch64')
url="https://github.com/newsniper-org/logicutils"
license=('BSD-2-Clause')
depends=('gcc-libs')
makedepends=('rust' 'cargo')
optdepends=(
    'slurm-llnl: SLURM cluster backend for lu-queue'
    'gridengine: SGE cluster backend for lu-queue'
    'openpbs:    PBS cluster backend for lu-queue'
)
provides=(
    'freshcheck' 'stamp'
    'lu-match' 'lu-expand'
    'lu-query'  'lu-rule'
    'lu-queue'  'lu-par' 'lu-deps'
    'lu-multi'
)
conflicts=(
    "${pkgname}-git"
    "${pkgname}-multi" "${pkgname}-multi-git"
    "${pkgname}-hpc"   "${pkgname}-hpc-git"
)
options=('!lto')
source=("${pkgname}-${pkgver}.tar.gz::${url}/archive/refs/tags/v${pkgver}.tar.gz")
sha256sums=('SKIP')

prepare() {
    cd "${pkgname}-${pkgver}"
    export RUSTUP_TOOLCHAIN=stable
    cargo fetch --locked --target "$(rustc -vV | sed -n 's/host: //p')"
}

build() {
    cd "${pkgname}-${pkgver}"
    export RUSTUP_TOOLCHAIN=stable
    export CARGO_TARGET_DIR=target
    cargo build --release --workspace --frozen
}

check() {
    cd "${pkgname}-${pkgver}"
    export RUSTUP_TOOLCHAIN=stable
    cargo test --release --workspace --frozen
}

package() {
    cd "${pkgname}-${pkgver}"

    # Install all individual utility binaries.
    local bins=(
        freshcheck stamp
        lu-match lu-expand
        lu-query lu-rule
        lu-queue lu-par lu-deps
        lu-multi
    )
    for bin in "${bins[@]}"; do
        install -Dm755 "target/release/${bin}" "${pkgdir}/usr/bin/${bin}"
    done

    # Man pages.
    local man_dir="${pkgdir}/usr/share/man"
    install -Dm644 docs/man/freshcheck.1 "${man_dir}/man1/freshcheck.1"
    install -Dm644 docs/man/stamp.1      "${man_dir}/man1/stamp.1"
    install -Dm644 docs/man/lu-match.1   "${man_dir}/man1/lu-match.1"
    install -Dm644 docs/man/lu-expand.1  "${man_dir}/man1/lu-expand.1"
    install -Dm644 docs/man/lu-query.1   "${man_dir}/man1/lu-query.1"
    install -Dm644 docs/man/lu-rule.1    "${man_dir}/man1/lu-rule.1"
    install -Dm644 docs/man/lu-queue.1   "${man_dir}/man1/lu-queue.1"
    install -Dm644 docs/man/lu-par.1     "${man_dir}/man1/lu-par.1"
    install -Dm644 docs/man/lu-deps.1    "${man_dir}/man1/lu-deps.1"
    install -Dm644 docs/man/lu-multi.1   "${man_dir}/man1/lu-multi.1"
    install -Dm644 docs/man/lu-kb.5      "${man_dir}/man5/lu-kb.5"

    # Project documentation.
    install -Dm644 README.md "${pkgdir}/usr/share/doc/${pkgname}/README.md"
    install -dm755 "${pkgdir}/usr/share/doc/${pkgname}/agents"
    cp -r docs/agents/. "${pkgdir}/usr/share/doc/${pkgname}/agents/"

    # License (Arch convention places it under /usr/share/licenses).
    install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
